# URL of the Clyde backend (FastMCP + Starlette). Clyde stays on localhost;
# the Next.js server-side proxy at /api/clyde/* forwards here.
CLYDE_BACKEND_URL=http://localhost:8765

# WebSocket URL for live state updates. The browser connects directly — Next.js
# route handlers cannot upgrade WebSockets — so this must be reachable from the
# client. NEXT_PUBLIC_ exposes it to the browser bundle at build time.
NEXT_PUBLIC_CLYDE_WS_URL=ws://localhost:8765/api/ws
